{
  "name": "desafio-qa-sea-tecnologia",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Exploração, automação e documentação QA da aplicação de cadastro de trabalhadores.",
  "scripts": {
    "test": "playwright test",
    "test:web": "playwright test tests/web",
    "test:api": "playwright test tests/api",
    "test:smoke": "playwright test tests/api/employees-get.spec.js tests/web/ui-api-consistency.spec.js",
    "test:deep-audit": "playwright test tests/web/employee-advanced.spec.js tests/api/employees-validation.spec.js tests/api/employees-methods-and-cache.spec.js",
    "test:shell": "playwright test tests/web/shell-navigation-and-content.spec.js",
    "test:security": "playwright test tests/api/employees-security.spec.js tests/api/security-hardening.spec.js",
    "test:deeper": "playwright test tests/web/deeper-ui-audit.spec.js tests/api/data-integrity-and-concurrency.spec.js",
    "test:headed": "playwright test tests/web --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:bug": "node scripts/run-bug.js",
    "list:tests": "node node_modules/@playwright/test/cli.js test --list"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1"
  }
}
